class Node:
    def __init__(self, data):
        self.data = data
        self.next = None

# membuat node
 n1 = Node(10)
 n2 = Node(20)

n1.next = n2

print(n1.data)  # Output: 10
print(n1.next.data)  # Output: 20

# penjelasan
# Node ~struktur dasar linked list
# data ~pointer ke node berikutnya
